# ── LLM Search Configuration ────────────────────────────────
# Copy to .env and edit if you want to override defaults:
#   cp .env.example .env
#
# Most users don't need this file. The defaults work out of the box:
#   - SearXNG for search (no API key)
#   - LM Studio at localhost:1234
#   - Middleware on port 8000

# --- Search Provider ---
# searxng (default) — self-hosted, no API key needed
# brave — Brave Search API (needs SEARCH_API_KEY)
# serpapi — SerpAPI (needs SEARCH_API_KEY)
# SEARCH_PROVIDER=searxng
# SEARXNG_URL=http://searxng:8080
# SEARCH_API_KEY=

# --- LM Studio ---
# LM_STUDIO_URL=http://host.docker.internal:1234/v1

# --- Middleware ---
# MIDDLEWARE_PORT=8000

# --- Chat Client ---
# CHAT_CLIENT_PORT=8080

# --- Limits ---
# MAX_TOOL_LOOP_ITERATIONS=10
# SEARCH_CACHE_TTL_SECONDS=300
# RATE_LIMIT_PER_MINUTE=30
# MAX_SEARCH_RESULTS=5

# --- Logging ---
# LOG_LEVEL=INFO
